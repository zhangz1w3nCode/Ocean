{
  "name": "ocean",
  "version": "1.0.4",
  "description": "Ocean",
  "main": "electron/launch.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/launch.cjs\"",
    "electron:preview": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/launch.cjs",
    "build": "tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.ocean.app",
    "productName": "Ocean",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.19.0",
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.14",
    "@dagrejs/dagre": "^2.0.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lezer/highlight": "^1.2.3",
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-ai": "^0.57.1",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "@uiw/codemirror-extensions-mentions": "^4.25.5",
    "@uiw/codemirror-themes-all": "^4.25.5",
    "@uiw/react-codemirror": "^4.25.4",
    "@xyflow/react": "^12.10.0",
    "d3-force": "^3.0.0",
    "framer-motion": "^12.34.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.12.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/d3-force": "^3.0.10",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "40.4.0",
    "electron-builder": "^26.7.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "wait-on": "^9.0.4"
  }
}
